# --------------------------------------------------
# SF-86 Application - Environment Variables
# --------------------------------------------------
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# --------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://sf86user:sf86dev_password@localhost:5432/sf86

# PDF microservice base URL
PDF_SERVICE_URL=http://localhost:8001

# AES-256 encryption key for PII data in section_data table
# MUST be exactly 32 characters in production
ENCRYPTION_KEY=change-this-in-production-use-32-chars

# NextAuth.js session signing secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-random-secret

# NextAuth.js canonical URL
NEXTAUTH_URL=http://localhost:3000
